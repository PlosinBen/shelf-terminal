# claude-agent-sdk 0.3.143+ declares @anthropic-ai/sdk and
# @modelcontextprotocol/sdk as peerDeps. We pin @anthropic-ai/sdk directly,
# but `npm install` and `npm ci` still flag the chain as conflicting without
# this flag. Setting at .npmrc level keeps local dev and CI consistent so
# package-lock.json doesn't fork between strict vs legacy resolution.
legacy-peer-deps=true
