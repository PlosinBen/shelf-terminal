{
  "name": "shelf-terminal",
  "version": "0.2.0",
  "description": "Cross-platform, project-based terminal manager",
  "main": "dist/main/index.js",
  "scripts": {
    "dev": "NODE_ENV=development vite",
    "build": "vite build",
    "postinstall": "electron-rebuild",
    "test:e2e": "NODE_ENV=test npm run build && NODE_ENV=test npx playwright test",
    "pack": "npm run build && npx electron-builder --dir",
    "dist": "npm run build && npx electron-builder",
    "dist:mac": "npm run build && npx electron-builder --mac",
    "dist:win": "npm run build && npx electron-builder --win",
    "dist:linux": "npm run build && npx electron-builder --linux"
  },
  "build": {
    "appId": "com.shelf.terminal",
    "productName": "Shelf",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "node_modules/node-pty/**/*"
    ],
    "mac": {
      "target": ["dmg", "zip"],
      "category": "public.app-category.developer-tools"
    },
    "win": {
      "target": ["nsis", "zip"]
    },
    "linux": {
      "target": ["AppImage", "deb"],
      "category": "Development"
    },
    "publish": {
      "provider": "github"
    }
  },
  "author": "PlosinBen <plosinben@gmail.com>",
  "license": "MIT",
  "devDependencies": {
    "@electron/rebuild": "4.0.3",
    "@playwright/test": "1.59.1",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "4.7.0",
    "electron": "41.1.1",
    "electron-builder": "26.8.1",
    "typescript": "5.9.3",
    "vite": "6.4.2",
    "vite-plugin-electron": "0.29.1",
    "vite-plugin-electron-renderer": "0.14.6"
  },
  "dependencies": {
    "@xterm/addon-fit": "0.11.0",
    "@xterm/addon-search": "^0.16.0",
    "@xterm/xterm": "6.0.0",
    "electron-updater": "^6.8.3",
    "node-pty": "1.1.0",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  }
}
