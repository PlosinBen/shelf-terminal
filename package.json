{
  "name": "shelf-terminal",
  "version": "2.4.2",
  "description": "Cross-platform, project-based terminal manager",
  "main": "dist/main/index.js",
  "scripts": {
    "dev": "vite build && node agent-server/build.mjs && NODE_ENV=development vite",
    "build": "vite build && node agent-server/build.mjs",
    "postinstall": "electron-rebuild",
    "typecheck": "tsc --noEmit",
    "test": "npm run typecheck && npm run test:unit && npm run test:e2e && npm run test:docker && npm run test:ssh",
    "test:unit": "vitest run",
    "test:e2e": "NODE_ENV=test npm run build && NODE_ENV=test npx playwright test --project=e2e",
    "test:docker": "docker run -d --name shelf-test-container -p 2222:2222 -e USER_NAME=testuser -e USER_PASSWORD=testpass -e PASSWORD_ACCESS=true linuxserver/openssh-server && NODE_ENV=test npm run build && NODE_ENV=test npx playwright test --project=docker; docker rm -f shelf-test-container",
    "test:ssh": "docker run -d --name shelf-test-container -p 2222:2222 -e USER_NAME=testuser -e USER_PASSWORD=testpass -e PASSWORD_ACCESS=true linuxserver/openssh-server && NODE_ENV=test npm run build && NODE_ENV=test npx playwright test --project=ssh; docker rm -f shelf-test-container",
    "pack": "npm run build && npx electron-builder --dir",
    "dist": "npm run build && npx electron-builder",
    "dist:mac": "npm run build && npx electron-builder --mac",
    "dist:win": "npm run build && npx electron-builder --win",
    "dist:linux": "npm run build && npx electron-builder --linux"
  },
  "build": {
    "appId": "com.shelf.terminal",
    "productName": "Shelf",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "!dist/agent-server",
      "node_modules/node-pty/**/*",
      "node_modules/@anthropic-ai/claude-agent-sdk-*/**/*",
      "node_modules/@github/copilot-sdk/**/*",
      "!node_modules/@github/copilot/**/*",
      "!node_modules/@github/copilot-darwin-*/**/*",
      "!node_modules/@github/copilot-linux-*/**/*",
      "!node_modules/@github/copilot-win32-*/**/*"
    ],
    "asarUnpack": [
      "node_modules/@anthropic-ai/claude-agent-sdk-*/claude",
      "node_modules/@anthropic-ai/claude-agent-sdk-*/claude.exe"
    ],
    "extraResources": [
      {
        "from": "dist/agent-server",
        "to": "agent-server"
      },
      {
        "from": "node_modules/@github/copilot",
        "to": "copilot-cli",
        "filter": [
          "**/*"
        ]
      }
    ],
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "category": "public.app-category.developer-tools"
    },
    "win": {
      "target": [
        "nsis",
        "zip"
      ]
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "Development"
    },
    "publish": {
      "provider": "github"
    }
  },
  "author": "PlosinBen <plosinben@gmail.com>",
  "license": "MIT",
  "devDependencies": {
    "@electron/rebuild": "4.0.3",
    "@playwright/test": "1.59.1",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "4.7.0",
    "electron": "41.1.1",
    "electron-builder": "26.8.1",
    "esbuild": "^0.28.0",
    "terser": "^5.46.1",
    "typescript": "5.9.3",
    "vite": "6.4.2",
    "vite-plugin-electron": "0.29.1",
    "vite-plugin-electron-renderer": "0.14.6",
    "vitest": "^4.1.4"
  },
  "dependencies": {
    "@ai-sdk/openai": "^3.0.58",
    "@anthropic-ai/claude-agent-sdk": "^0.3.159",
    "@anthropic-ai/sdk": "^0.100.1",
    "@github/copilot-sdk": "1.0.0-beta.1",
    "@xterm/addon-fit": "0.11.0",
    "@xterm/addon-search": "^0.16.0",
    "@xterm/addon-unicode11": "^0.9.0",
    "@xterm/addon-web-links": "^0.12.0",
    "@xterm/addon-webgl": "^0.19.0",
    "@xterm/xterm": "6.0.0",
    "ai": "^6.0.174",
    "electron-updater": "^6.8.3",
    "idb": "^8.0.3",
    "marked": "^18.0.2",
    "node-pty": "1.1.0",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  }
}
